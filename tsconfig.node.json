{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "es2021",
    "downlevelIteration": true,
    "composite": true,
    "types": [
      "electron-vite/node",
    ],
  }
}
