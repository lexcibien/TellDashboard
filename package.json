{
  "name": "tell-dashboard",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "lexcibien",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "echo 'Starting format...' && prettier --log-level warn --write .",
    "lint": "echo 'Starting lint...' && eslint --cache .",
    "typecheck:node": "echo 'Starting typecheck for node...' && tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "echo 'Starting typecheck for web...' && tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "echo 'Running all typechecks...' && yarn typecheck:node && yarn typecheck:web",
    "dedupe:packages": "echo 'Running dedupe for packages...' && yarn dedupe --strategy highest",
    "start": "electron-vite preview --mode production",
    "dev": "electron-vite dev",
    "build": "yarn lint && yarn format && yarn typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "yarn build && electron-builder --dir",
    "build:win": "yarn build && electron-builder --win",
    "build:mac": "yarn build && electron-builder --mac",
    "build:linux": "yarn build && electron-builder --linux",
    "app:version": "echo $npm_package_version",
    "create:release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@types/node": "25.0.10",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "electron": "40.0.0",
    "electron-builder": "26.6.0",
    "electron-vite": "^5.0.0",
    "eslint": "10.0.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.12.0",
    "trucksim-telemetry": "^1.0.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
